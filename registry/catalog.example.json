{
  "version": 1,
  "systems": [
    {
      "alias": "local",
      "description": "Current local development machine",
      "transport": "local",
      "working_directory": ".",
      "env": {
        "TEST_ENV": "dev"
      }
    },
    {
      "alias": "lab-a",
      "description": "Remote hardware validation host",
      "transport": "ssh",
      "hostname": "lab-a.internal.example",
      "username": "runner",
      "port": 22,
      "auth_method": "ssh_key",
      "ssh_config_host": "lab-a",
      "credential_ref": "ssh-config:lab-a",
      "working_directory": "/opt/test-suite"
    },
    {
      "alias": "lab-password",
      "description": "Remote host using password-based SSH auth",
      "transport": "ssh",
      "hostname": "192.168.1.50",
      "username": "root",
      "port": 22,
      "auth_method": "password",
      "password_env_var": "LAB_PASSWORD_SSH_PASSWORD",
      "credential_ref": "env:LAB_PASSWORD_SSH_PASSWORD",
      "working_directory": "/opt/test-suite"
    }
  ],
  "entries": [
    {
      "alias": "lt",
      "description": "Run local smoke tests",
      "execution_type": "python_script",
      "target": "scripts/local_smoke.py",
      "system": "local",
      "args": [
        "--quick"
      ],
      "keywords": [
        "local smoke",
        "smoke suite"
      ],
      "timeout": 90
    },
    {
      "alias": "device-check",
      "description": "Run hardware validation binary",
      "execution_type": "executable",
      "target": "./bin/device-check",
      "system": "lab-a",
      "keywords": [
        "hardware validation",
        "device validation"
      ],
      "timeout": 300
    }
  ]
}
