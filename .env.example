# Dataiku LLM Mesh OpenAI-compatible endpoint
DATAIKU_LLM_MESH_URL=https://your-dataiku-instance.com/api/v1
DATAIKU_API_KEY=your-api-key-here

# Model configuration
DATAIKU_MODEL_ID=your-model-id

# Generic LLM config (used by Settings)
LLM_BASE_URL=https://your-dataiku-instance.com/api/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Autonomy policy: "conservative" | "moderate" | "aggressive"
AUTONOMY_POLICY=conservative

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
